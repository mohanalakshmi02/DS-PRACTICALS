#include <stdio.h>

struct Student
{
    int regno;
    char name[30];
    float marks;
};

int main()
{
    struct Student s;

    printf("Enter Register Number: ");
    scanf("%d", &s.regno);

    printf("Enter Name: ");
    scanf("%s", s.name);

    printf("Enter Marks: ");
    scanf("%f", &s.marks);

    printf("\nStudent Details\n");
    printf("Register Number : %d\n", s.regno);
    printf("Name            : %s\n", s.name);
    printf("Marks           : %.2f\n", s.marks);

    return 0;
}
